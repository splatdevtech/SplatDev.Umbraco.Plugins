{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Properties Report",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.PropertiesReport.Dashboard",
      "name": "Properties Report Dashboard",
      "element": "/App_Plugins/PropertiesReport/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "properties-report-dashboard",
      "meta": {
        "label": "Properties",
        "pathname": "properties-report"
      }
    }
  ],
  "alias": "SplatDev.PropertiesReport"
}
