{
  "$schema": "../../umbraco-package-schema.json",
  "name": "PDF Curator",
  "version": "1.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.PdfCurator.Dashboard",
      "name": "PDF Curator Dashboard",
      "element": "/App_Plugins/PdfCurator/dist/pdf-curator-dashboard.element.js",
      "elementName": "pdf-curator-dashboard",
      "weight": 100,
      "meta": {
        "label": "#pdfCurator_dashboardLabel",
        "pathname": "pdf-curator"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "SplatDev.PdfCurator.Localization.En",
      "name": "PDF Curator — English",
      "meta": {
        "culture": "en",
        "localizations": {
          "section": {
            "pdfCurator_heading": "PDF Curator",
            "pdfCurator_description": "Manage PDF digital books and documents",
            "pdfCurator_library": "Library",
            "pdfCurator_upload": "Upload PDF"
          }
        }
      }
    },
    {
      "type": "localization",
      "alias": "SplatDev.PdfCurator.Localization.PtBr",
      "name": "PDF Curator — Português (Brasil)",
      "meta": {
        "culture": "pt-BR",
        "localizations": {
          "section": {
            "pdfCurator_heading": "Curador de PDF",
            "pdfCurator_description": "Gerenciar PDFs e livros digitais",
            "pdfCurator_library": "Biblioteca",
            "pdfCurator_upload": "Enviar PDF"
          }
        }
      }
    }
  ]
}