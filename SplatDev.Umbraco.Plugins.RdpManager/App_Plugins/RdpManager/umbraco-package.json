{
  "$schema": "../../umbraco-package-schema.json",
  "name": "RDP Manager",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.RdpManager.Dashboard",
      "name": "RDP Manager Dashboard",
      "element": "/App_Plugins/RdpManager/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "rdp-manager-dashboard",
      "meta": {
        "label": "RDP Manager",
        "pathname": "rdp-manager"
      }
    }
  ],
  "alias": "SplatDev.RdpManager"
}
