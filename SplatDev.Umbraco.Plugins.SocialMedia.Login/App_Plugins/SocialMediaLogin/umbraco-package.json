{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Social Media Login",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.SocialLogin.Dashboard",
      "name": "Social Login Dashboard",
      "element": "/App_Plugins/SocialMediaLogin/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "social-login-dashboard",
      "meta": {
        "label": "Social Login",
        "pathname": "social-login"
      }
    }
  ],
  "alias": "SplatDev.SocialLogin"
}
