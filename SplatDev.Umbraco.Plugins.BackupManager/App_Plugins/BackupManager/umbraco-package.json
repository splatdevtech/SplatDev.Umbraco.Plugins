{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Backup Manager",
  "version": "1.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.BackupManager.Dashboard",
      "name": "Backup Manager Dashboard",
      "element": "/App_Plugins/BackupManager/dist/backup-manager-dashboard.element.js",
      "elementName": "backup-manager-dashboard",
      "weight": 100,
      "meta": {
        "label": "#backupManager_dashboardLabel",
        "pathname": "backup-manager"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "SplatDev.BackupManager.Localization.En",
      "name": "Backup Manager — English",
      "meta": {
        "culture": "en",
        "localizations": {
          "section": {
            "backupManager_heading": "Backup Manager",
            "backupManager_description": "Manage site backups and cloud storage providers",
            "backupManager_runNow": "Run Backup Now",
            "backupManager_schedule": "Schedule"
          }
        }
      }
    },
    {
      "type": "localization",
      "alias": "SplatDev.BackupManager.Localization.PtBr",
      "name": "Backup Manager — Português (Brasil)",
      "meta": {
        "culture": "pt-BR",
        "localizations": {
          "section": {
            "backupManager_heading": "Gerenciador de Backup",
            "backupManager_description": "Gerenciar backups do site e provedores de armazenamento em nuvem",
            "backupManager_runNow": "Executar Backup Agora",
            "backupManager_schedule": "Agendamento"
          }
        }
      }
    }
  ]
}