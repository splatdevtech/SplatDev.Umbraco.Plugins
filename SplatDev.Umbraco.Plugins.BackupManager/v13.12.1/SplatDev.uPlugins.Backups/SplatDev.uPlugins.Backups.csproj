<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>net8.0</TargetFrameworks>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<ContentTargetFolders>.</ContentTargetFolders>
	</PropertyGroup>

	<PropertyGroup>
		<PackageId>SplatDev.uPlugins.Backups</PackageId>
		<Product>SplatDev.uPlugins.Backups</Product>
		<Title>SplatDev.uPlugins.Backups</Title>
		<Description>Backup manager plugin for Umbraco — full and incremental backups of files and database. Supports Umbraco 13 (net8.0).</Description>
		<Version>2.0.0</Version>
		<Authors>SplatDev</Authors>
		<PackageTags>umbraco plugin package backup</PackageTags>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="13.12.0" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SplatDev.Plugins.BackupVault\SplatDev.Plugins.BackupVault.csproj" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="App_Plugins\SplatDev.uPlugins.Backups\**" ExcludeFromSingleFile="true" CopyToPublishDirectory="Always" />
		<None Include="buildTransitive\**" Pack="true" PackagePath="buildTransitive" />
	</ItemGroup>
</Project>

