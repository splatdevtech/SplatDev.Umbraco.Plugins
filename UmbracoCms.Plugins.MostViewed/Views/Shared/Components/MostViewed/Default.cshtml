@model UmbracoCms.Plugins.MostViewed.Models.PageViewSummary[]
@{
    var items = Model ?? Array.Empty<UmbracoCms.Plugins.MostViewed.Models.PageViewSummary>();
}

<div class="most-viewed">
    <h3 class="most-viewed__title">Most Viewed</h3>

    @if (!items.Any())
    {
        <p class="most-viewed__empty">No page views recorded yet.</p>
    }
    else
    {
        <ol class="most-viewed__list">
            @foreach (var item in items)
            {
                <li class="most-viewed__item">
                    <a href="@item.NodeUrl" class="most-viewed__link">@item.NodeName</a>
                    <span class="most-viewed__count">@item.ViewCount view@(item.ViewCount == 1 ? "" : "s")</span>
                </li>
            }
        </ol>
    }
</div>

<style>
    .most-viewed { font-family: inherit; }
    .most-viewed__title { font-size: 1.1rem; font-weight: 600; margin-bottom: 8px; }
    .most-viewed__list { margin: 0; padding-left: 1.25rem; }
    .most-viewed__item { display: flex; justify-content: space-between; align-items: baseline; padding: 4px 0; border-bottom: 1px solid #f0f0f0; }
    .most-viewed__link { color: inherit; text-decoration: none; flex: 1; }
    .most-viewed__link:hover { text-decoration: underline; }
    .most-viewed__count { font-size: 0.8rem; color: #888; white-space: nowrap; margin-left: 8px; }
    .most-viewed__empty { color: #888; font-style: italic; }
</style>
