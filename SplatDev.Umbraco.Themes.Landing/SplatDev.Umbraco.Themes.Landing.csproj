<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>SplatDev.Umbraco.Themes.Landing</PackageId>
    <Version>1.0.0</Version>
    <Authors>SplatDev</Authors>
    <Company>SplatDev</Company>
    <Copyright>Copyright © 2026 SplatDev</Copyright>
    <Description>Landing page theme for Umbraco - hero section, features grid, testimonials, pricing cards, FAQ accordion, CTA banner</Description>
    <PackageTags>umbraco umbraco-marketplace theme landing landing-page</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/SplatDev-Ltda/umbraco-themes</PackageProjectUrl>
    <RepositoryUrl>https://github.com/SplatDev-Ltda/umbraco-themes</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
    <PackageReference Include="SplatDev.Umbraco.Plugins.Yaml2Schema" Version="1.0.35" />
    <PackageReference Include="SplatDev.Umbraco.Themes.Base" Version="1.0.0" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
    <PackageReference Include="SplatDev.Umbraco.Plugins.Yaml2Schema" Version="1.0.35" />
    <PackageReference Include="SplatDev.Umbraco.Themes.Base" Version="1.0.0" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Config\umbraco.yml" />
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <None Include="Views\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Include="wwwroot\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
