<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>SplatDev.Umbraco.Plugins.Backups</PackageId>
    <Version>3.1.1</Version>
    <Authors>SplatDev</Authors>
    <Description>Backup plugin for Umbraco — create and manage backups from the backoffice. Supports cloud storage providers: Azure Blob, Google Drive, Dropbox, Box, OneDrive, Mega, Seafile, Amazon S3, SFTP, and local file system. Supports Umbraco 13 (net8.0) and Umbraco 17 (net10.0).</Description>
    <PackageTags>umbraco umbraco-marketplace backup restore export cloud-storage azure-blob s3 dropbox sftp</PackageTags>
    <Company>SplatDev Ltda</Company>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Plugins</PackageProjectUrl>
    <RepositoryUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Plugins</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
    <PackageReference Include="Azure.Storage.Blobs" Version="12.22.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
    <PackageReference Include="Azure.Storage.Blobs" Version="12.23.0" />
  </ItemGroup>

  <!-- Cloud storage provider SDKs — compatible with .NET Standard 2.0, net8.0, and net10.0 -->
  <ItemGroup>
    <PackageReference Include="Dropbox.Api" Version="5.5.0" />
    <PackageReference Include="MegaApiClient" Version="1.10.5" />
    <PackageReference Include="AWSSDK.S3" Version="3.7.303" />
    <PackageReference Include="SSH.NET" Version="2025.1.0" />
  </ItemGroup>

  <!-- Exclude legacy archive — these files have their own sub-projects with missing SDKs -->
  <ItemGroup>
    <Compile Remove="v13.12.1\**" />
    <None Remove="v13.12.1\**" />
    <Content Remove="v13.12.1\**" />
    <EmbeddedResource Remove="v13.12.1\**" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="App_Plugins\**\*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="umbraco-marketplace.json" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
