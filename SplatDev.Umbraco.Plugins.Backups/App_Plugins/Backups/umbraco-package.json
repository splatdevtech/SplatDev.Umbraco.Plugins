{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Backups",
  "version": "3.1.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "UmbracoCms.Backups.Dashboard",
      "name": "Backups Dashboard",
      "element": "/App_Plugins/Backups/dist/backups-dashboard.element.js",
      "elementName": "backups-dashboard",
      "weight": 100,
      "meta": {
        "label": "Backups",
        "pathname": "backups"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "UmbracoCms.Backups.Localization.En",
      "name": "Backups — English",
      "meta": {
        "culture": "en",
        "localizations": {
          "section": {
            "backups_heading": "Backups",
            "backups_description": "Create, restore, and schedule backups from the backoffice",
            "backups_create": "Create Backup",
            "backups_delete": "Delete",
            "backups_restore": "Restore",
            "backups_schedule": "Schedule",
            "backups_includeMedia": "Include Media",
            "backups_compress": "Compress (ZIP)",
            "backups_encrypt": "Encrypt",
            "backups_scope": "Scope",
            "backups_scope_content": "Content",
            "backups_scope_media": "Media",
            "backups_scope_database": "Database",
            "backups_scope_full": "Full (Content + Media + Database)",
            "backups_cloudProvider": "Cloud Provider",
            "backups_testConnection": "Test Connection",
            "backups_provider_local": "Local File System",
            "backups_provider_azure": "Azure Blob Storage",
            "backups_provider_googledrive": "Google Drive",
            "backups_provider_dropbox": "Dropbox",
            "backups_provider_box": "Box.net",
            "backups_provider_onedrive": "OneDrive",
            "backups_provider_mega": "Mega",
            "backups_provider_seafile": "Seafile",
            "backups_provider_s3": "Amazon S3",
            "backups_provider_sftp": "SFTP"
          }
        }
      }
    }
  ]
}
