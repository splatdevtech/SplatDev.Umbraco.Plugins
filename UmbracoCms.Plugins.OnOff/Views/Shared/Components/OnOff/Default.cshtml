@using UmbracoCms.Plugins.OnOff.Models
@model IEnumerable<FeatureToggle>

<div class="onoff-component">
    @if (!Model.Any())
    {
        <p class="onoff-empty">No feature toggles configured.</p>
    }
    else
    {
        <ul class="onoff-list">
            @foreach (var feature in Model)
            {
                <li class="onoff-item @(feature.IsEnabled ? "onoff-enabled" : "onoff-disabled")">
                    <span class="onoff-name">@feature.Name</span>
                    <span class="onoff-badge">@(feature.IsEnabled ? "ON" : "OFF")</span>
                    @if (!string.IsNullOrEmpty(feature.Description))
                    {
                        <small class="onoff-description">@feature.Description</small>
                    }
                </li>
            }
        </ul>
    }
</div>

<style>
    .onoff-list { list-style: none; margin: 0; padding: 0; }
    .onoff-item { display: flex; align-items: center; gap: 12px; padding: 8px 0; border-bottom: 1px solid #e5e7eb; }
    .onoff-name { font-weight: 600; flex: 1; }
    .onoff-badge { padding: 2px 10px; border-radius: 9999px; font-size: 0.75rem; font-weight: 700; }
    .onoff-enabled .onoff-badge { background: #d1fae5; color: #065f46; }
    .onoff-disabled .onoff-badge { background: #fee2e2; color: #991b1b; }
    .onoff-description { color: #6b7280; font-size: 0.8rem; }
    .onoff-empty { color: #6b7280; }
</style>
