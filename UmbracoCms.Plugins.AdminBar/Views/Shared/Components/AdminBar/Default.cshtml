@model UmbracoCms.Plugins.AdminBar.ViewComponents.AdminBarViewModel

@if (Model.IsLoggedIn)
{
    <div id="umbraco-admin-bar" style="position:fixed;top:0;left:0;width:100%;z-index:99999;background:#1b264f;color:#fff;display:flex;align-items:center;gap:12px;padding:6px 16px;font-family:sans-serif;font-size:13px;box-shadow:0 2px 6px rgba(0,0,0,.4);">
        <span style="font-weight:600;opacity:.7;">Umbraco</span>
        @if (Model.NodeId > 0)
        {
            <span style="opacity:.5;">|</span>
            <span>@Model.NodeName</span>
            <a href="/umbraco#/content/content/edit/@Model.NodeId"
               target="_blank"
               style="color:#8ab4f8;text-decoration:none;padding:2px 8px;border:1px solid #8ab4f8;border-radius:3px;">
                Edit Page
            </a>
            <a href="/umbraco/preview/?id=@Model.NodeId"
               target="_blank"
               style="color:#a8d5a2;text-decoration:none;padding:2px 8px;border:1px solid #a8d5a2;border-radius:3px;">
                Preview
            </a>
            <button onclick="adminBarPublish(@Model.NodeId)"
                    style="color:#f9c74f;background:transparent;border:1px solid #f9c74f;border-radius:3px;cursor:pointer;padding:2px 8px;font-size:13px;">
                Publish
            </button>
        }
        <span style="margin-left:auto;opacity:.6;">@Model.UserName</span>
        <a href="/umbraco" target="_blank" style="color:#ccc;text-decoration:none;">Backoffice</a>
    </div>
    <div style="height:34px;"></div>

    <script>
        function adminBarPublish(nodeId) {
            fetch('/umbraco/api/adminbar/PublishPage?nodeId=' + nodeId, { method: 'POST' })
                .then(r => r.json())
                .then(d => alert(d.message))
                .catch(() => alert('Publish failed.'));
        }
    </script>
}
