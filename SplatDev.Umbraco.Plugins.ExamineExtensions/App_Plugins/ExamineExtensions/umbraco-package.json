{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Examine Extensions",
  "version": "1.0.0",
  "allowPackageTelemetry": false,
  "extensions": [
    {
      "type": "dashboard",
      "alias": "examineExtensions.dashboard",
      "name": "Examine Extensions Dashboard",
      "element": "/App_Plugins/ExamineExtensions/examine-extensions-dashboard.js",
      "weight": -10,
      "meta": {
        "label": "Examine Extensions",
        "pathname": "examine-extensions"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    }
  ]
}
