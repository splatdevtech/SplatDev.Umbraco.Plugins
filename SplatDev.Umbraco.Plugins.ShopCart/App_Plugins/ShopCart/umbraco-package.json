{
  "$schema": "../../umbraco-package-schema.json",
  "name": "ShopCart",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.ShopCart.Dashboard",
      "name": "ShopCart Dashboard",
      "element": "/App_Plugins/ShopCart/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "shop-cart-dashboard",
      "meta": {
        "label": "Shop Cart",
        "pathname": "shop-cart"
      }
    }
  ],
  "alias": "SplatDev.ShopCart"
}
