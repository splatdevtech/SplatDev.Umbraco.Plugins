<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>net8.0;net10.0</TargetFrameworks>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<ContentTargetFolders>.</ContentTargetFolders>
		<Company>SplatDev Ltda</Company>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Plugins</PackageProjectUrl>
		<RepositoryUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Plugins</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
	</PropertyGroup>

	<PropertyGroup>
		<PackageId>SplatDev.Umbraco.Plugins.Mailer</PackageId>
		<Product>SplatDev.Umbraco.Plugins.Mailer</Product>
		<Title>SplatDev.Umbraco.Plugins.Mailer</Title>
		<Description>Umbraco mailer plugin supporting Umbraco 13 (net8.0) and Umbraco 17 (net10.0)</Description>
		<PackageTags>umbraco umbraco-marketplace email mail smtp</PackageTags>
		<Version>2.0.0</Version>
    <PackageReadmeFile>README.md</PackageReadmeFile>
		<Authors>SplatDev</Authors>
	</PropertyGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="13.12.0" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Api.Management" Version="17.3.4" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\SplatDev.Umbraco.Common\SplatDev.Umbraco.Common.csproj" />
		<ProjectReference Include="..\SplatDev.Umbraco.Markup\SplatDev.Umbraco.Markup.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Azure.Identity" Version="1.13.2" />
		<PackageReference Include="Microsoft.Graph" Version="5.73.0" />
		<PackageReference Include="Microsoft.Identity.Client" Version="4.69.1" />
		<PackageReference Include="MailKit" Version="4.15.1" />
		<PackageReference Include="MimeKit" Version="4.15.1" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="App_Plugins\Umbraco.Plugins.Mailer\**" ExcludeFromSingleFile="true" CopyToPublishDirectory="Always" />
		<None Include="buildTransitive\**" Pack="true" PackagePath="buildTransitive" />
	</ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="umbraco-marketplace.json" Pack="true" PackagePath="\" Condition="Exists('umbraco-marketplace.json')" />
  </ItemGroup>
</Project>
