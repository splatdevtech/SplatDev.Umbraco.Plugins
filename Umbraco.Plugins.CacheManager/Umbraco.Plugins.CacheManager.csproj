<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<TargetFrameworks>net8.0;net10.0</TargetFrameworks>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<ContentTargetFolders>.</ContentTargetFolders>
	</PropertyGroup>

	<PropertyGroup>
		<PackageId>Umbraco.Plugins.CacheWarmer</PackageId>
		<Product>Umbraco.Plugins.CacheWarmer</Product>
		<Title>Umbraco.Plugins.CacheWarmer</Title>
		<Description>Umbraco cache manager/warmer plugin supporting Umbraco 13 (net8.0) and Umbraco 17 (net10.0)</Description>
		<PackageTags>umbraco umbraco-marketplace</PackageTags>
		<Version>2.0.0</Version>
		<Authors>SplatDev</Authors>
	</PropertyGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Infrastructure" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="13.12.0" />
		<PackageReference Include="Microsoft.EntityFrameworkCore" Version="8.0.20" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="8.0.20">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.EntityFrameworkCore.DynamicLinq" Version="8.6.8" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="8.0.20" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="8.0.20">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="EFCoreSecondLevelCacheInterceptor" Version="5.3.2" />
		<PackageReference Include="EFCoreSecondLevelCacheInterceptor.MemoryCache" Version="5.3.2" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Infrastructure" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Api.Management" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="17.3.4" />
		<PackageReference Include="Microsoft.EntityFrameworkCore" Version="10.0.7" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="10.0.7">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.EntityFrameworkCore.DynamicLinq" Version="10.6.8" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="10.0.7" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="10.0.7">
			<PrivateAssets>all</PrivateAssets>
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="EFCoreSecondLevelCacheInterceptor" Version="5.3.9" />
		<PackageReference Include="EFCoreSecondLevelCacheInterceptor.MemoryCache" Version="5.3.9" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="HtmlAgilityPack" Version="1.12.4" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\Umbraco.Plugins.Mailer\Umbraco.Plugins.Mailer.csproj" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="App_Plugins\Umbraco.Plugins.CacheWarmer\**" ExcludeFromSingleFile="true" CopyToPublishDirectory="Always" />
		<None Include="buildTransitive\**" Pack="true" PackagePath="buildTransitive" />
	</ItemGroup>

	<ItemGroup>
		<Content Remove="App_Plugins\Umbraco.Plugins.CacheWarmer\package.manifest" />
	</ItemGroup>
</Project>
