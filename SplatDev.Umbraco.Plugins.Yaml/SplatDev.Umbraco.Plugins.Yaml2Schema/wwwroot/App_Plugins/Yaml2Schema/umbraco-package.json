{
  "$schema": "https://json.schemastore.org/umbraco-package.json",
  "name": "Yaml2Schema",
  "version": "1.0.35",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "Yaml.Import.Dashboard",
      "name": "YAML Import",
      "element": "/App_Plugins/Yaml2Schema/dashboard.js",
      "elementName": "yaml2schema-dashboard",
      "weight": 110,
      "meta": {
        "label": "YAML Import",
        "pathname": "yaml-import"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    }
  ]
}
