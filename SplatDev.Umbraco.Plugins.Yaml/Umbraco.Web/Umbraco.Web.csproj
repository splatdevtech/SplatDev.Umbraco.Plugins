<Project Sdk="Microsoft.NET.Sdk.Web">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <CompressionEnabled>false</CompressionEnabled> <!-- Disable compression. E.g. for umbraco backoffice files. These files should be precompressed by node and not let dotnet handle it -->
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Umbraco.Cms" Version="17.3.4" />
    <PackageReference Include="Umbraco.Cms.DevelopmentMode.Backoffice" Version="17.3.4" />
    <PackageReference Include="Umbraco.TheStarterKit" Version="17.0.0" />
  </ItemGroup>


  <ItemGroup>
    <!-- Opt-in to app-local ICU to ensure consistent globalization APIs across different platforms -->
    <PackageReference Include="Microsoft.ICU.ICU4C.Runtime" Version="72.1.0.3" />
    <RuntimeHostConfigurationOption Include="System.Globalization.AppLocalIcu" Value="72.1.0.3" Condition="$(RuntimeIdentifier.StartsWith('linux')) or $(RuntimeIdentifier.StartsWith('win')) or ('$(RuntimeIdentifier)' == '' and !$([MSBuild]::IsOSPlatform('osx')))" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SplatDev.Umbraco.Plugins.Yaml2Schema\SplatDev.Umbraco.Plugins.Yaml2Schema.csproj" />
    <ProjectReference Include="..\SplatDev.Umbraco.Plugins.Schema2Yaml\SplatDev.Umbraco.Plugins.Schema2Yaml.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="umbraco\Data\" />
  </ItemGroup>

  <PropertyGroup>
    <!-- Razor files are needed for the backoffice to work correctly -->
    <CopyRazorGenerateFilesToPublishDirectory>true</CopyRazorGenerateFilesToPublishDirectory>
  </PropertyGroup>

  <!--
    Copy App_Plugins from project-referenced plugin libraries into this project's wwwroot.
    The buildTransitive/*.targets mechanism only fires for NuGet consumers; for ProjectReferences
    we must do this explicitly so Umbraco discovers the umbraco-package.json manifests.
  -->
  <Target Name="CopyPluginAppPlugins" AfterTargets="Build">
    <ItemGroup>
      <_PluginAppPluginFiles
          Include="$(MSBuildThisFileDirectory)..\SplatDev.Umbraco.Plugins.Schema2Yaml\wwwroot\App_Plugins\**\*.*" />
      <_PluginAppPluginFiles
          Include="$(MSBuildThisFileDirectory)..\SplatDev.Umbraco.Plugins.Yaml2Schema\wwwroot\App_Plugins\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_PluginAppPluginFiles)"
          DestinationFolder="$(MSBuildProjectDirectory)\wwwroot\App_Plugins\%(RecursiveDir)"
          SkipUnchangedFiles="true" />
  </Target>

  <PropertyGroup>
    <!-- Remove RazorCompileOnBuild and RazorCompileOnPublish when not using ModelsMode InMemoryAuto -->
    <RazorCompileOnBuild>false</RazorCompileOnBuild>
    <RazorCompileOnPublish>false</RazorCompileOnPublish>
  </PropertyGroup>

</Project>
