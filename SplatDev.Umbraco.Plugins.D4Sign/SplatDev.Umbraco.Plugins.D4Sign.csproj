<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
	<TargetFrameworks>net8.0;net10.0</TargetFrameworks>
	<ImplicitUsings>enable</ImplicitUsings>
	<Nullable>enable</Nullable>
	<GenerateEmbeddedFilesManifest>true</GenerateEmbeddedFilesManifest>
	<PackageId>SplatDev.Umbraco.Plugins.D4Sign</PackageId>
	<Version>1.0.1</Version>
    <PackageReadmeFile>README.md</PackageReadmeFile>
	<Description>D4Sign digital signature integration for Umbraco. Supports document upload, signer management, webhook processing, and a Lit 3 backoffice dashboard. Supports Umbraco 13 (net8.0) and Umbraco 17 (net10.0).</Description>
	<PackageTags>umbraco umbraco-marketplace d4sign digital-signature assinatura-digital brazil</PackageTags>
  </PropertyGroup>

  <ItemGroup>
	<FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
	<!-- Polly is the same major version across both TFMs -->
	<PackageReference Include="Microsoft.Extensions.Http.Polly" Version="8.0.11" Condition="'$(TargetFramework)' == 'net8.0'" />
	<PackageReference Include="Microsoft.Extensions.Http.Polly" Version="8.0.11" Condition="'$(TargetFramework)' == 'net10.0'" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
	<PackageReference Include="Umbraco.Cms.Core"       Version="13.12.0" />
	<PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
	<PackageReference Include="Umbraco.Cms.Core"       Version="17.3.4" />
	<PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
  </ItemGroup>

  <ItemGroup>
	<EmbeddedResource Include="App_Plugins\**\*" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="umbraco-marketplace.json" Pack="true" PackagePath="\" Condition="Exists('umbraco-marketplace.json')" />
  </ItemGroup>
</Project>
