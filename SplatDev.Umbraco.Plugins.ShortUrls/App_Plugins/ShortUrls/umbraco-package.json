{
  "$schema": "../../umbraco-package-schema.json",
  "name": "ShortUrls",
  "version": "1.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "ShortUrls.Dashboard",
      "name": "Short URLs Dashboard",
      "element": "/App_Plugins/ShortUrls/dist/short-urls-dashboard.element.js",
      "elementName": "short-urls-dashboard",
      "weight": 100,
      "meta": {
        "label": "#shortUrls_dashboardLabel",
        "pathname": "short-urls"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "SplatDev.ShortUrls.Localization.En",
      "name": "ShortUrls — English",
      "meta": {
        "culture": "en",
        "localizations": {
          "section": {
            "shortUrls_heading": "Short URLs",
            "shortUrls_description": "Manage short URL redirects",
            "shortUrls_create": "Create Short URL",
            "shortUrls_shortCode": "Short Code"
          }
        }
      }
    },
    {
      "type": "localization",
      "alias": "SplatDev.ShortUrls.Localization.PtBr",
      "name": "ShortUrls — Português (Brasil)",
      "meta": {
        "culture": "pt-BR",
        "localizations": {
          "section": {
            "shortUrls_heading": "URLs Curtas",
            "shortUrls_description": "Gerenciar redirecionamentos de URLs curtas",
            "shortUrls_create": "Criar URL Curta",
            "shortUrls_shortCode": "Código Curto"
          }
        }
      }
    }
  ]
}