{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Social Media Share",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.SocialShare.Dashboard",
      "name": "Social Media Share Dashboard",
      "element": "/App_Plugins/SocialMediaShare/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
