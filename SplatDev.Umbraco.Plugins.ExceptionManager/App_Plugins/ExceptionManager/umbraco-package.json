{
  "$schema": "../../umbraco-package-schema.json",
  "name": "ExceptionManager",
  "version": "1.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "ExceptionManager.Dashboard",
      "name": "Exception Manager Dashboard",
      "element": "/App_Plugins/ExceptionManager/dist/exception-manager-dashboard.element.js",
      "elementName": "exception-manager-dashboard",
      "weight": 100,
      "meta": {
        "label": "#exceptionManager_dashboardLabel",
        "pathname": "exception-manager"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "SplatDev.ExceptionManager.Localization.En",
      "name": "ExceptionManager — English",
      "meta": {
        "culture": "en",
        "localizations": {
          "section": {
            "exceptionManager_heading": "Exception Manager",
            "exceptionManager_description": "Monitor and review application exceptions",
            "exceptionManager_refresh": "Refresh",
            "exceptionManager_filter": "Filter"
          }
        }
      }
    },
    {
      "type": "localization",
      "alias": "SplatDev.ExceptionManager.Localization.PtBr",
      "name": "ExceptionManager — Português (Brasil)",
      "meta": {
        "culture": "pt-BR",
        "localizations": {
          "section": {
            "exceptionManager_heading": "Gerenciador de Exceções",
            "exceptionManager_description": "Monitorar e revisar exceções da aplicação",
            "exceptionManager_refresh": "Atualizar",
            "exceptionManager_filter": "Filtrar"
          }
        }
      }
    }
  ]
}