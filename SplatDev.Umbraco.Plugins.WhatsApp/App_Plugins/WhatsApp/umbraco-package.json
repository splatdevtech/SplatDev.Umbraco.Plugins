{
  "$schema": "../../umbraco-package-schema.json",
  "name": "WhatsApp Chat Button",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.WhatsApp.Dashboard",
      "name": "WhatsApp Dashboard",
      "element": "/App_Plugins/WhatsApp/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "whatsapp-dashboard",
      "meta": {
        "label": "WhatsApp",
        "pathname": "whatsapp"
      }
    }
  ],
  "alias": "SplatDev.WhatsApp"
}
