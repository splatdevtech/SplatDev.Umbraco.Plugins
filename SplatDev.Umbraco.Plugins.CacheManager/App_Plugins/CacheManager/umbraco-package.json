{
  "$schema": "../../umbraco-package-schema.json",
  "name": "SplatDev Cache Manager",
  "alias": "SplatDev.CacheManager",
  "version": "1.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.CacheManager.Dashboard",
      "name": "Cache Manager Dashboard",
      "element": "/App_Plugins/CacheManager/dist/cache-manager.js",
      "elementName": "cache-manager-dashboard",
      "weight": 10,
      "meta": {
        "label": "Cache Manager",
        "pathname": "cache-manager"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "SplatDev.CacheManager.Localization.En",
      "name": "Cache Manager — English",
      "meta": {
        "culture": "en",
        "localizations": {
          "section": {
            "cacheManager_heading": "Cache Manager",
            "cacheManager_description": "Manage the Umbraco content cache and monitor warm-up activity.",
            "cacheManager_clearCache": "Clear Cache",
            "cacheManager_refreshCache": "Refresh Cache",
            "cacheManager_statistics": "Cache Statistics",
            "cacheManager_history": "Warm-up History",
            "cacheManager_notFound": "404 URLs"
          }
        }
      }
    },
    {
      "type": "localization",
      "alias": "SplatDev.CacheManager.Localization.PtBr",
      "name": "Cache Manager — Português (Brasil)",
      "meta": {
        "culture": "pt-BR",
        "localizations": {
          "section": {
            "cacheManager_heading": "Gerenciador de Cache",
            "cacheManager_description": "Gerencie o cache de conteúdo do Umbraco e monitore a atividade de aquecimento.",
            "cacheManager_clearCache": "Limpar Cache",
            "cacheManager_refreshCache": "Atualizar Cache",
            "cacheManager_statistics": "Estatísticas de Cache",
            "cacheManager_history": "Histórico de Aquecimento",
            "cacheManager_notFound": "URLs 404"
          }
        }
      }
    }
  ]
}
