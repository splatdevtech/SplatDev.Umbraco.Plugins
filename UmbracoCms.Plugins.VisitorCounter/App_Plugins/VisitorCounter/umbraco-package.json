{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Visitor Counter",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "UmbracoCms.VisitorCounter.Dashboard",
      "name": "Visitor Counter Dashboard",
