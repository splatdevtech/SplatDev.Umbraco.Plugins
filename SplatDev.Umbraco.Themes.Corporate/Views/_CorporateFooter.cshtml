@model Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent
@{
    var companyName = Model?.Value<string>("companyName") ?? "Company";
    var email       = Model?.Value<string>("email");
    var phone       = Model?.Value<string>("phone");
    var address     = Model?.Value<string>("address");
    var linkedIn    = Model?.Value<Umbraco.Cms.Core.Models.PublishedContent.IHtmlEncodedString>("linkedIn");
    var twitter     = Model?.Value<Umbraco.Cms.Core.Models.PublishedContent.IHtmlEncodedString>("twitter");
    var facebook    = Model?.Value<Umbraco.Cms.Core.Models.PublishedContent.IHtmlEncodedString>("facebook");
    var instagram   = Model?.Value<Umbraco.Cms.Core.Models.PublishedContent.IHtmlEncodedString>("instagram");
    var youtube     = Model?.Value<Umbraco.Cms.Core.Models.PublishedContent.IHtmlEncodedString>("youtube");
}
<footer class="site-footer" role="contentinfo">
    <div class="container footer-inner">
        <div class="footer-brand">
            <span class="footer-logo-text">@companyName</span>
            <p class="footer-tagline">@(Model?.Value<string>("tagline") ?? "")</p>
            <div class="footer-social">
                @if (linkedIn != null)
                {
                    <a href="@linkedIn.ToHtmlString()" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="@companyName on LinkedIn">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M17 17h-3v-4.6c0-1.1-.4-1.9-1.4-1.9-.8 0-1.2.5-1.4 1-.1.2-.1.5-.1.8V17H8s.1-9 0-10h3v1.4c.4-.6 1.1-1.5 2.7-1.5 2 0 3.3 1.3 3.3 4.1V17zM4.4 5.6C3.4 5.6 2.7 5 2.7 4S3.5 2.4 4.4 2.4c1 0 1.6.6 1.6 1.6 0 .9-.6 1.6-1.6 1.6zM3 17V7h3v10H3z"/></svg>
                    </a>
                }
                @if (twitter != null)
                {
                    <a href="@twitter.ToHtmlString()" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="@companyName on Twitter">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M17.3 3h-2.6L10 8.4 5.8 3H2.7L8.9 11.2 2.7 17h2.6l4.4-5 4.6 5h3L11.1 8.6 17.3 3z"/></svg>
                    </a>
                }
                @if (facebook != null)
                {
                    <a href="@facebook.ToHtmlString()" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="@companyName on Facebook">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M17 1H3a2 2 0 00-2 2v14a2 2 0 002 2h7v-7H8V9h2V7c0-2.2 1.3-3.5 3.3-3.5.9 0 1.9.1 2.7.2V6h-1.8c-1 0-1.2.5-1.2 1.2V9h2.3l-.3 3H13v7h4a2 2 0 002-2V3a2 2 0 00-2-2z"/></svg>
                    </a>
                }
                @if (instagram != null)
                {
                    <a href="@instagram.ToHtmlString()" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="@companyName on Instagram">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="16" height="16" rx="4"/><circle cx="10" cy="10" r="3.5"/><circle cx="14.5" cy="5.5" r=".8" fill="currentColor" stroke="none"/></svg>
                    </a>
                }
                @if (youtube != null)
                {
                    <a href="@youtube.ToHtmlString()" class="social-link" target="_blank" rel="noopener noreferrer" aria-label="@companyName on YouTube">
                        <svg width="18" height="18" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path d="M17.6 5.7A2.2 2.2 0 0016 4.1C14.6 3.7 10 3.7 10 3.7s-4.6 0-6 .4a2.2 2.2 0 00-1.6 1.6C2 7.1 2 10 2 10s0 2.9.4 4.3a2.2 2.2 0 001.6 1.6c1.4.4 6 .4 6 .4s4.6 0 6-.4a2.2 2.2 0 001.6-1.6c.4-1.4.4-4.3.4-4.3s0-2.9-.4-4.3zM8.3 12.8V7.2l4.5 2.8-4.5 2.8z"/></svg>
                    </a>
                }
            </div>
        </div>

        <div class="footer-nav">
            <h3 class="footer-nav-title">Navigation</h3>
            <ul>
                @foreach (var child in Model?.Children?.Where(c => !c.Value<bool>("hideFromNavigation"))
                    ?? Enumerable.Empty<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>())
                {
                    <li><a href="@child.Url()">@child.Name</a></li>
                }
            </ul>
        </div>

        @if (!string.IsNullOrWhiteSpace(email) || !string.IsNullOrWhiteSpace(phone) || !string.IsNullOrWhiteSpace(address))
        {
            <div class="footer-contact">
                <h3 class="footer-nav-title">Contact</h3>
                <address class="footer-address">
                    @if (!string.IsNullOrWhiteSpace(email))
                    {
                        <p><a href="mailto:@email">@email</a></p>
                    }
                    @if (!string.IsNullOrWhiteSpace(phone))
                    {
                        <p><a href="tel:@phone">@phone</a></p>
                    }
                    @if (!string.IsNullOrWhiteSpace(address))
                    {
                        <p>@address</p>
                    }
                </address>
            </div>
        }
    </div>
    <div class="footer-bottom">
        <div class="container">
            <p>&copy; @DateTime.Now.Year @companyName. All rights reserved.</p>
        </div>
    </div>
</footer>
