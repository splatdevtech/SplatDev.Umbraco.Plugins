@model FieldViewModel
@using FormBuilder.Core.Models
@using FormBuilder.Web.Extensions

@{
    var i = 0;
    var displayLayout = (Model.GetSettingValue<string>("DisplayLayout", "Vertical") ?? string.Empty).ToLower();
}

<div class="checkboxlist" id="@Model.Id" data-umb="@Model.Id">
    @foreach (PrevalueViewModel pv in Model.PreValues)
    {
        <div class="form-check@(@displayLayout == "horizontal" ? " form-check-inline" : string.Empty)">
            <input type="checkbox"
                   class="form-check-input"
                   name="@Model.Name" id="@string.Concat(Model.Id,"_",i)" data-umb="@string.Concat(Model.Id, "_", i)" value="@pv.Value"
            @(Model.Mandatory ? $"data-val=\"true\" data-val-required=\"{Model.RequiredErrorMessage}\" data-rule-required=\"true\" data-msg-required=\"{Model.RequiredErrorMessage}\"" : "")
            @(Model.ContainsValue(pv.Value) ? "checked=\"checked\"" : "") />

            <label class="form-check-label" for="@string.Concat(Model.Id,"_",i)">@pv.Caption</label>
        </div>
        i++;
    }
</div>
