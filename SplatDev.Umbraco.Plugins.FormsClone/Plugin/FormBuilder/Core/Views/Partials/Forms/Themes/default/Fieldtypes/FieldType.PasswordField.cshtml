@model FieldViewModel
@using FormBuilder.Core.Extensions
@using FormBuilder.Core.Models
@using FormBuilder.Web.Extensions

<input type="password" name="@Model.Name" id="@Model.Id" data-umb="@Model.Id" spellcheck="false" class="@Html.GetFormFieldClass(Model.FieldTypeName) text" value="@Model.ValueAsHtmlString"
@(string.IsNullOrEmpty(Model.PlaceholderText) == false ? $"placeholder=\"{Model.PlaceholderText}\"" : "")
@(Model.Mandatory || Model.Validate ? "data-val=\"true\"" : "")
@(Model.Mandatory ? $"data-val-required=\"{Model.RequiredErrorMessage}\" aria-required=\"true\"" : "")
@(Model.Validate ? $"data-val-regex=\"{Model.InvalidErrorMessage}\" data-val-regex-pattern=\"{Model.Regex}\"" : "")
@(!string.IsNullOrEmpty(Model.ToolTip) ? $"aria-describedby=\"{(Model.Id)}_description\"" : "") />
