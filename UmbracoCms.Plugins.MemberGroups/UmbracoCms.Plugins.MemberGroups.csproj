<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackageId>UmbracoCms.Plugins.MemberGroups</PackageId>
    <Version>2.0.0</Version>
    <Authors>SplatDev</Authors>
    <Description>Member group management for Umbraco: assign/remove groups, bulk operations, group-based content access. Supports Umbraco 13 (net8.0) and Umbraco 17 (net10.0).</Description>
    <PackageTags>umbraco umbraco-marketplace member groups</PackageTags>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="App_Plugins\**\*" />
    <None Include="Views\**\*">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
