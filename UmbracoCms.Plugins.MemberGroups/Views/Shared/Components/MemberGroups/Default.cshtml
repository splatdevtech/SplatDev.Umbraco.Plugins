@using Umbraco.Cms.Core.Models

<div class="member-groups-component">
    <div class="mg-section">
        <h3>Member Groups</h3>
        @if (ViewBag.Groups is IEnumerable<IMemberGroup> groups && groups.Any())
        {
            <ul class="mg-list">
                @foreach (var group in groups)
                {
                    <li class="mg-item">
                        <strong>@group.Name</strong>
                        <span class="mg-id">(ID: @group.Id)</span>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="mg-empty">No member groups found.</p>
        }
    </div>

    <div class="mg-section">
        <h3>Member Types</h3>
        @if (ViewBag.Types is IEnumerable<IMemberType> types && types.Any())
        {
            <ul class="mg-list">
                @foreach (var type in types)
                {
                    <li class="mg-item">
                        <strong>@type.Name</strong>
                        <code class="mg-alias">@type.Alias</code>
                    </li>
                }
            </ul>
        }
        else
        {
            <p class="mg-empty">No member types found.</p>
        }
    </div>
</div>

<style>
    .member-groups-component { font-family: inherit; }
    .mg-section { margin-bottom: 2rem; }
    .mg-section h3 { margin: 0 0 .75rem; font-size: 1.1rem; font-weight: 600; }
    .mg-list { list-style: none; margin: 0; padding: 0; }
    .mg-item { padding: .5rem; border-bottom: 1px solid #e5e7eb; display: flex; align-items: center; gap: .75rem; }
    .mg-id { font-size: .8rem; color: #6b7280; }
    .mg-alias { background: #f3f4f6; padding: 1px 8px; border-radius: 4px; font-size: .8rem; }
    .mg-empty { color: #6b7280; }
</style>
