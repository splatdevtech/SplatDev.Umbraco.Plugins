<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net10.0</TargetFrameworks>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<PackageId>SplatDev.Umbraco.Authorization.Ldap</PackageId>
		<Version>2.0.0</Version>
		<Authors>SplatDev</Authors>
		<Title>SplatDev.Umbraco.Authorization.Ldap</Title>
		<Description>LDAP/Active Directory SSO authentication for Umbraco 13 (net8.0) and Umbraco 17 (net10.0)</Description>
		<PackageTags>umbraco umbraco-marketplace ldap sso active-directory</PackageTags>
		<Company>SplatDev Ltda</Company>
		<PackageIcon>icon.png</PackageIcon>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Plugins</PackageProjectUrl>
		<RepositoryUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Plugins</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
	</PropertyGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="8.0.13" />
		<PackageReference Include="System.DirectoryServices" Version="8.0.1" />
		<PackageReference Include="System.DirectoryServices.AccountManagement" Version="8.0.1" />
		<PackageReference Include="System.DirectoryServices.Protocols" Version="8.0.1" />
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="13.12.0" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Negotiate" Version="10.0.0" />
		<PackageReference Include="System.DirectoryServices" Version="10.0.5" />
		<PackageReference Include="System.DirectoryServices.AccountManagement" Version="10.0.5" />
		<PackageReference Include="System.DirectoryServices.Protocols" Version="10.0.5" />
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Api.Management" Version="17.3.4" />
	</ItemGroup>

	<!-- AzureSSO files need Microsoft.Identity.Web + OpenIdConnect packages — exclude until properly integrated -->
	<ItemGroup>
		<Compile Remove="src/Umbraco.Community.AzureSSO/**" />
	</ItemGroup>

  <ItemGroup>
    <None Include="icon.png" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
