<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>SplatDev.Umbraco.CodeFirst</PackageId>
    <Version>2.0.0</Version>
    <Authors>SplatDev</Authors>
    <Description>[DEPRECATED] Code-first content type definitions for Umbraco. Use SplatDev.Umbraco.Plugins.Yaml2Schema instead. Supports Umbraco 13 (net8.0) and Umbraco 17 (net10.0).</Description>
    <PackageTags>umbraco code-first content-types deprecated umbraco-marketplace</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <!-- Suppress warnings from obsolete internal patterns -->
    <NoWarn>$(NoWarn);CS0618;CS0612</NoWarn>
    <Company>SplatDev Ltda</Company>
    <PackageProjectUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Core</PackageProjectUrl>
    <RepositoryUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Core</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
    <PackageReference Include="Umbraco.Cms.Infrastructure" Version="13.12.0" />
    <PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="13.12.0" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
    <PackageReference Include="Umbraco.Cms.Infrastructure" Version="17.3.4" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\SplatDev.Umbraco.Plugins\SplatDev.Umbraco.Plugins.csproj" />
  </ItemGroup>
</Project>
