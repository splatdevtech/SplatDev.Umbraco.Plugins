{
  "$schema": "../../umbraco-package-schema.json",
  "name": "GDPR Compliance",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.Gdrp.Dashboard",
      "name": "GDPR Dashboard",
      "element": "/App_Plugins/Gdrp/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "gdrp-dashboard",
      "meta": {
        "label": "GDPR",
        "pathname": "gdpr-compliance"
      }
    }
  ],
  "alias": "SplatDev.Gdrp"
}
