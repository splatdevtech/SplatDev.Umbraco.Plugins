@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = null;
    var root = Model.Root();
    var confName = root?.Value<string>("confName") ?? "Conference";
    var registrationUrl = root?.Value<Umbraco.Cms.Core.Models.Link>("registrationUrl");

    var pageTitle = Model.Value<string>("pageTitle") ?? "Speakers";
    var intro = Model.Value<string>("intro") ?? string.Empty;

    var speakers = Model.Children?.Where(x => x.ContentType.Alias == "speaker") ?? Enumerable.Empty<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>();
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle – @confName</title>
    @if (!string.IsNullOrWhiteSpace(intro))
    {
        <meta name="description" content="@intro" />
    }
    <link rel="stylesheet" href="/css/conference-theme.css" />
</head>
<body class="conf-speakers-listing">

    <header class="conf-header">
        <div class="conf-container conf-header__inner">
            <a href="/" class="conf-header__brand"><span class="conf-header__name">@confName</span></a>
            @if (registrationUrl != null)
            {
                <a href="@registrationUrl.Url" class="conf-btn conf-btn--primary conf-header__cta" target="@(registrationUrl.Target ?? "_self")">Register Now</a>
            }
        </div>
    </header>

    <main class="conf-main">
        <div class="conf-container">

            <div class="conf-page-header">
                <h1 class="conf-page-header__title">@pageTitle</h1>
                @if (!string.IsNullOrWhiteSpace(intro))
                {
                    <p class="conf-page-header__intro">@intro</p>
                }
            </div>

            @if (speakers.Any())
            {
                <div class="conf-speaker-grid conf-speaker-grid--full">
                    @foreach (var sp in speakers)
                    {
                        var photo = sp.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("photo");
                        var fullName = sp.Value<string>("fullName") ?? sp.Name;
                        var jobTitle = sp.Value<string>("jobTitle") ?? string.Empty;
                        var company = sp.Value<string>("company") ?? string.Empty;
                        var country = sp.Value<string>("country") ?? string.Empty;
                        <a href="@sp.Url()" class="conf-speaker-card">
                            <div class="conf-speaker-card__photo">
                                @if (photo != null)
                                {
                                    <img src="@photo.Url()" alt="@fullName" loading="lazy" />
                                }
                                else
                                {
                                    <div class="conf-speaker-card__placeholder">@fullName[0]</div>
                                }
                            </div>
                            <div class="conf-speaker-card__info">
                                <h2 class="conf-speaker-card__name">@fullName</h2>
                                @if (!string.IsNullOrWhiteSpace(jobTitle))
                                {
                                    <p class="conf-speaker-card__title">@jobTitle</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(company))
                                {
                                    <p class="conf-speaker-card__company">@company</p>
                                }
                                @if (!string.IsNullOrWhiteSpace(country))
                                {
                                    <p class="conf-speaker-card__country">@country</p>
                                }
                            </div>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="conf-empty">No speakers have been added yet.</p>
            }

        </div>
    </main>

    <footer class="conf-footer">
        <div class="conf-container conf-footer__inner">
            <p class="conf-footer__name">@confName</p>
        </div>
    </footer>

</body>
</html>
