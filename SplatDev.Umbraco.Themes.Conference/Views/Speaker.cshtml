@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = null;
    var root = Model.Root();
    var confName = root?.Value<string>("confName") ?? "Conference";
    var registrationUrl = root?.Value<Umbraco.Cms.Core.Models.Link>("registrationUrl");

    var fullName = Model.Value<string>("fullName") ?? Model.Name;
    var jobTitle = Model.Value<string>("jobTitle") ?? string.Empty;
    var company = Model.Value<string>("company") ?? string.Empty;
    var bio = Model.Value<IHtmlContent>("bio");
    var photo = Model.Value<Umbraco.Cms.Core.Models.PublishedContent.IPublishedContent>("photo");
    var country = Model.Value<string>("country") ?? string.Empty;

    var twitterUrl = Model.Value<Umbraco.Cms.Core.Models.Link>("twitterUrl");
    var linkedInUrl = Model.Value<Umbraco.Cms.Core.Models.Link>("linkedInUrl");
    var websiteUrl = Model.Value<Umbraco.Cms.Core.Models.Link>("websiteUrl");
    var youtubeUrl = Model.Value<Umbraco.Cms.Core.Models.Link>("youtubeUrl");

    var speakersListing = Model.Parent;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@fullName – @confName</title>
    <meta name="description" content="@jobTitle@(!string.IsNullOrWhiteSpace(company) ? $" at {company}" : "") – Speaker at @confName" />
    <link rel="stylesheet" href="/css/conference-theme.css" />
</head>
<body class="conf-speaker-detail">

    <!-- ========== HEADER ========== -->
    <header class="conf-header">
        <div class="conf-container conf-header__inner">
            <a href="/" class="conf-header__brand"><span class="conf-header__name">@confName</span></a>
            <nav class="conf-nav" aria-label="Main navigation">
                <ul class="conf-nav__list">
                    @if (speakersListing != null)
                    {
                        <li><a href="@speakersListing.Url()">All Speakers</a></li>
                    }
                </ul>
            </nav>
            @if (registrationUrl != null)
            {
                <a href="@registrationUrl.Url" class="conf-btn conf-btn--primary conf-header__cta" target="@(registrationUrl.Target ?? "_self")">Register Now</a>
            }
        </div>
    </header>

    <!-- ========== SPEAKER PROFILE ========== -->
    <main class="conf-main">
        <div class="conf-container">

            <!-- Breadcrumb -->
            <nav class="conf-breadcrumb" aria-label="Breadcrumb">
                <a href="/">Home</a>
                <span aria-hidden="true"> / </span>
                @if (speakersListing != null)
                {
                    <a href="@speakersListing.Url()">Speakers</a>
                    <span aria-hidden="true"> / </span>
                }
                <span aria-current="page">@fullName</span>
            </nav>

            <article class="conf-speaker-profile">
                <div class="conf-speaker-profile__hero">
                    <div class="conf-speaker-profile__photo-wrap">
                        @if (photo != null)
                        {
                            <img src="@photo.Url()" alt="@fullName" class="conf-speaker-profile__photo" />
                        }
                        else
                        {
                            <div class="conf-speaker-profile__placeholder">@fullName[0]</div>
                        }
                    </div>
                    <div class="conf-speaker-profile__identity">
                        <h1 class="conf-speaker-profile__name">@fullName</h1>
                        @if (!string.IsNullOrWhiteSpace(jobTitle))
                        {
                            <p class="conf-speaker-profile__title">@jobTitle</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(company))
                        {
                            <p class="conf-speaker-profile__company">@company</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(country))
                        {
                            <p class="conf-speaker-profile__country">@country</p>
                        }

                        <!-- Social Links -->
                        @{
                            bool hasSocial = twitterUrl != null || linkedInUrl != null || websiteUrl != null || youtubeUrl != null;
                        }
                        @if (hasSocial)
                        {
                            <div class="conf-speaker-profile__social">
                                @if (twitterUrl != null)
                                {
                                    <a href="@twitterUrl.Url" class="conf-social-link conf-social-link--twitter" target="_blank" rel="noopener" aria-label="Twitter">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                                    </a>
                                }
                                @if (linkedInUrl != null)
                                {
                                    <a href="@linkedInUrl.Url" class="conf-social-link conf-social-link--linkedin" target="_blank" rel="noopener" aria-label="LinkedIn">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                                    </a>
                                }
                                @if (websiteUrl != null)
                                {
                                    <a href="@websiteUrl.Url" class="conf-social-link conf-social-link--website" target="_blank" rel="noopener" aria-label="Website">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/></svg>
                                    </a>
                                }
                                @if (youtubeUrl != null)
                                {
                                    <a href="@youtubeUrl.Url" class="conf-social-link conf-social-link--youtube" target="_blank" rel="noopener" aria-label="YouTube">
                                        <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>

                <!-- Bio -->
                @if (bio != null)
                {
                    <div class="conf-speaker-profile__bio conf-prose">
                        <h2>About @fullName</h2>
                        @bio
                    </div>
                }
            </article>

            <!-- Back link -->
            @if (speakersListing != null)
            {
                <div class="conf-back-link">
                    <a href="@speakersListing.Url()" class="conf-btn conf-btn--outline">&larr; Back to Speakers</a>
                </div>
            }
        </div>
    </main>

    <!-- ========== FOOTER ========== -->
    <footer class="conf-footer">
        <div class="conf-container conf-footer__inner">
            <p class="conf-footer__name">@confName</p>
        </div>
    </footer>

</body>
</html>
