@inherits Umbraco.Cms.Web.Common.Views.UmbracoViewPage
@{
    Layout = null;
    var root = Model.Root();
    var confName = root?.Value<string>("confName") ?? "Conference";
    var registrationUrl = root?.Value<Umbraco.Cms.Core.Models.Link>("registrationUrl");

    var pageTitle = Model.Value<string>("pageTitle") ?? "Sponsors";
    var intro = Model.Value<string>("intro") ?? string.Empty;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle – @confName</title>
    <link rel="stylesheet" href="/css/conference-theme.css" />
</head>
<body class="conf-sponsors-page">

    <header class="conf-header">
        <div class="conf-container conf-header__inner">
            <a href="/" class="conf-header__brand"><span class="conf-header__name">@confName</span></a>
            @if (registrationUrl != null)
            {
                <a href="@registrationUrl.Url" class="conf-btn conf-btn--primary conf-header__cta">Register Now</a>
            }
        </div>
    </header>

    <main class="conf-main">
        <div class="conf-container">

            <div class="conf-page-header">
                <h1 class="conf-page-header__title">@pageTitle</h1>
                @if (!string.IsNullOrWhiteSpace(intro))
                {
                    <p class="conf-page-header__intro">@intro</p>
                }
            </div>

            <!-- Sponsor tiers are managed via Block List in the back-office.
                 This placeholder shows the structure when no block data is present. -->
            <div class="conf-sponsors-tiers" id="conf-sponsors-tiers">
                <div class="conf-sponsor-tier conf-sponsor-tier--gold">
                    <h2 class="conf-sponsor-tier__name">Gold Sponsors</h2>
                    <div class="conf-sponsor-tier__logos">
                        <p class="conf-empty-tier">Gold sponsor logos will appear here.</p>
                    </div>
                </div>
                <div class="conf-sponsor-tier conf-sponsor-tier--silver">
                    <h2 class="conf-sponsor-tier__name">Silver Sponsors</h2>
                    <div class="conf-sponsor-tier__logos">
                        <p class="conf-empty-tier">Silver sponsor logos will appear here.</p>
                    </div>
                </div>
                <div class="conf-sponsor-tier conf-sponsor-tier--bronze">
                    <h2 class="conf-sponsor-tier__name">Bronze Sponsors</h2>
                    <div class="conf-sponsor-tier__logos">
                        <p class="conf-empty-tier">Bronze sponsor logos will appear here.</p>
                    </div>
                </div>
            </div>

            <div class="conf-sponsor-cta">
                <h2>Become a Sponsor</h2>
                <p>Interested in sponsoring @confName? Get in touch with us.</p>
                @{
                    var email = root?.Value<string>("email") ?? string.Empty;
                }
                @if (!string.IsNullOrWhiteSpace(email))
                {
                    <a href="mailto:@email" class="conf-btn conf-btn--outline">Contact Us</a>
                }
            </div>

        </div>
    </main>

    <footer class="conf-footer">
        <div class="conf-container conf-footer__inner">
            <p class="conf-footer__name">@confName</p>
        </div>
    </footer>

</body>
</html>
