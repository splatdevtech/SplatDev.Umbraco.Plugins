<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net10.0</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>SplatDev.Umbraco.Markup</PackageId>
		<Version>2.0.0</Version>
		<Authors>SplatDev</Authors>
		<Description>HTML/markup helpers and extensions for Umbraco 13 (net8.0) and Umbraco 17 (net10.0)</Description>
		<PackageTags>umbraco umbraco-marketplace markup html</PackageTags>
		<Company>SplatDev Ltda</Company>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<PackageProjectUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Plugins</PackageProjectUrl>
		<RepositoryUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Plugins</RepositoryUrl>
		<RepositoryType>git</RepositoryType>
	</PropertyGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Infrastructure" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="13.12.0" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Infrastructure" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Api.Management" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Web.Website" Version="17.3.4" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
		<FrameworkReference Include="Microsoft.AspNetCore.App" />
	</ItemGroup>

</Project>
