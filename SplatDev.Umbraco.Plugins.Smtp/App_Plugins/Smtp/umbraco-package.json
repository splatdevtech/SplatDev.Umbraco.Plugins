{
  "$schema": "../../umbraco-package-schema.json",
  "name": "SMTP Configuration",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.Smtp.Dashboard",
      "name": "SMTP Dashboard",
      "element": "/App_Plugins/Smtp/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "smtp-dashboard",
      "meta": {
        "label": "SMTP",
        "pathname": "smtp-settings"
      }
    }
  ],
  "alias": "SplatDev.Smtp"
}
