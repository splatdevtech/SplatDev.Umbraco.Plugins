<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net10.0</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>SplatDev.Umbraco.Plugins.OAuth</PackageId>
		<Version>2.0.0</Version>
		<Authors>SplatDev</Authors>
		<Description>Umbraco OAuth social login plugin supporting Umbraco 13 (net8.0) and Umbraco 17 (net10.0)</Description>
		<PackageTags>umbraco umbraco-marketplace</PackageTags>
	</PropertyGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Facebook" Version="8.0.20" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Google" Version="8.0.20" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Twitter" Version="8.0.20" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Facebook" Version="9.0.9" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Google" Version="9.0.9" />
		<PackageReference Include="Microsoft.AspNetCore.Authentication.Twitter" Version="9.0.9" />
	</ItemGroup>

</Project>
