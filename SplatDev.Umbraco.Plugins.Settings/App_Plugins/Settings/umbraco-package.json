{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Site Settings Manager",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.Settings.Dashboard",
      "name": "Settings Dashboard",
      "element": "/App_Plugins/Settings/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "settings-dashboard",
      "meta": {
        "label": "Site Settings",
        "pathname": "site-settings"
      }
    }
  ],
  "alias": "SplatDev.Settings"
}
