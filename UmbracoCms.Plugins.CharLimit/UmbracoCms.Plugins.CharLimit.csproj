<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>UmbracoCms.Plugins.CharLimit</AssemblyName>
    <RootNamespace>UmbracoCms.Plugins.CharLimit</RootNamespace>
    <PackageId>UmbracoCms.Plugins.CharLimit</PackageId>
    <Version>1.0.0</Version>
    <Authors>SplatDev</Authors>
    <Company>SplatDev Ltda</Company>
    <Description>Character limit property editor for Umbraco — enforces max length on text properties with live counter display.</Description>
    <PackageTags>umbraco;umbraco-marketplace;plugin;splatdev</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageProjectUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Core</PackageProjectUrl>
    <RepositoryUrl>https://github.com/SplatDev-Ltda/SplatDev.Umbraco.Core</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="App_Plugins\**\*" />
  </ItemGroup>

</Project>
