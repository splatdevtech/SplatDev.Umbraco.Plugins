{
  "$schema": "../../umbraco-package-schema.json",
  "id": "SplatDev.EmailTemplates",
  "name": "SplatDev Email Templates",
  "version": "1.0.0",
  "allowPackageTelemetry": true,
  "extensions": [
    {
      "type": "section",
      "alias": "SplatDev.Section.EmailTemplates",
      "name": "Email Templates",
      "meta": {
        "label": "Email Templates",
        "pathname": "email-templates"
      }
    },
    {
      "type": "menuItem",
      "alias": "SplatDev.MenuItem.EmailTemplates",
      "name": "Email Templates Menu Item",
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "SplatDev.Section.EmailTemplates"
        }
      ],
      "meta": {
        "label": "Templates",
        "icon": "icon-mail",
        "entityType": "email-template",
        "menus": ["Umb.Menu.Default"]
      }
    },
    {
      "type": "menuItem",
      "alias": "SplatDev.MenuItem.EmailStyle",
      "name": "Email Style Menu Item",
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "SplatDev.Section.EmailTemplates"
        }
      ],
      "meta": {
        "label": "Style Settings",
        "icon": "icon-brush",
        "entityType": "email-style",
        "menus": ["Umb.Menu.Default"]
      }
    },
    {
      "type": "dashboard",
      "alias": "SplatDev.EmailTemplates.Dashboard",
      "name": "Email Templates Dashboard",
      "element": "/App_Plugins/SplatDev.EmailTemplates/dist/emailtemplates-dashboard.element.js",
      "elementName": "emailtemplates-dashboard",
      "weight": 0,
      "meta": {
        "label": "Templates",
        "pathname": "templates"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "SplatDev.Section.EmailTemplates"
        }
      ]
    },
    {
      "type": "dashboard",
      "alias": "SplatDev.EmailStyle.Dashboard",
      "name": "Email Style Dashboard",
      "element": "/App_Plugins/SplatDev.EmailTemplates/dist/emailstyles-dashboard.element.js",
      "elementName": "emailstyles-dashboard",
      "weight": 10,
      "meta": {
        "label": "Style Settings",
        "pathname": "style-settings"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "SplatDev.Section.EmailTemplates"
        }
      ]
    }
  ]
}
