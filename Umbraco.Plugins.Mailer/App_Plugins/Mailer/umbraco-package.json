{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Mailer",
  "version": "1.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "Mailer.Dashboard",
      "name": "Mailer Dashboard",
      "element": "/App_Plugins/Mailer/dist/mailer-dashboard.element.js",
      "elementName": "mailer-dashboard",
      "weight": 100,
      "meta": {
        "label": "#mailer_dashboardLabel",
        "pathname": "mailer"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "Mailer.Localization.En",
      "name": "Mailer English",
      "integrityHash": null,
      "meta": {
        "culture": "en"
      },
      "js": "/App_Plugins/Mailer/dist/mailer-dashboard.element.js",
      "translations": {
        "mailer_dashboardLabel": "Mailer",
        "mailer_heading": "Mailer Dashboard",
        "mailer_description": "Microsoft Graph email service integration"
      }
    },
    {
      "type": "localization",
      "alias": "Mailer.Localization.PtBR",
      "name": "Mailer Portuguese (Brazil)",
      "integrityHash": null,
      "meta": {
        "culture": "pt-BR"
      },
      "js": "/App_Plugins/Mailer/dist/mailer-dashboard.element.js",
      "translations": {
        "mailer_dashboardLabel": "Mailer",
        "mailer_heading": "Painel de E-mail",
        "mailer_description": "Integração com o serviço de e-mail Microsoft Graph"
      }
    }
  ]
}
