<Project Sdk="Microsoft.NET.Sdk.Web">
	<!--
	  REFERENCE IMPLEMENTATION ONLY — do not change TargetFramework here.
	  This project is a local development harness that runs Umbraco 15 (net9.0) and references
	  FormBuilder.Extension for smoke-testing. The distributable package is FormBuilder.Extension,
	  which multi-targets net8.0 (Umbraco 13 LTS) and net10.0 (Umbraco 17 LTS).
	-->
	<PropertyGroup>
		<TargetFramework>net9.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<CompressionEnabled>false</CompressionEnabled>
		<!-- Disable compression. E.g. for umbraco backoffice files. These files should be precompressed by node and not let dotnet handle it -->
	</PropertyGroup>

  <ItemGroup>
		<PackageReference Include="Microsoft.TypeScript.MSBuild" Version="5.8.1">
		  <PrivateAssets>all</PrivateAssets>
		  <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
		</PackageReference>
		<PackageReference Include="Umbraco.Cms" Version="15.3.1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../../../../../../SplatDev.Api.Common.ApiVersioning/SplatDev.Api.Common.ApiVersioning.csproj" />
  </ItemGroup>

	<ItemGroup>
		<!-- Opt-in to app-local ICU to ensure consistent globalization APIs across different platforms -->
		<PackageReference Include="Microsoft.ICU.ICU4C.Runtime" Version="72.1.0.3" />
		<PackageReference Include="uSync" Version="15.1.2" />
		<ProjectReference Include="..\FormBuilder.Extension\FormBuilder.Extension.csproj" />
		<RuntimeHostConfigurationOption Include="System.Globalization.AppLocalIcu" Value="72.1.0.3" Condition="$(RuntimeIdentifier.StartsWith('linux')) or $(RuntimeIdentifier.StartsWith('win')) or ('$(RuntimeIdentifier)' == '' and !$([MSBuild]::IsOSPlatform('osx')))" />
	</ItemGroup>

	<PropertyGroup>
		<!-- Razor files are needed for the backoffice to work correctly -->
		<CopyRazorGenerateFilesToPublishDirectory>true</CopyRazorGenerateFilesToPublishDirectory>
	</PropertyGroup>


</Project>
