<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AddRazorSupportForMvc>true</AddRazorSupportForMvc>
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>FormBuilder.Extension</PackageId>
    <Version>2.0.0</Version>
    <Authors>SplatDev</Authors>
    <Description>FormBuilder.Extension — an open-source Umbraco Forms alternative without per-site licensing requirements. Supports Umbraco 13 (net8.0) and Umbraco 17 (net10.0).</Description>
    <PackageTags>umbraco forms form-builder umbraco-marketplace</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <Product>FormBuilder.Extension</Product>
    <Title>FormBuilder.Extension</Title>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- Suppress transitive vulnerability warnings from Umbraco's own dependencies -->
  <PropertyGroup>
    <NoWarn>$(NoWarn);NU1902;NU1903</NoWarn>
  </PropertyGroup>

  <!-- Umbraco 14 packages (net8.0) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="[14.0.0, 15.0.0)" />
    <PackageReference Include="Umbraco.Cms.Infrastructure" Version="[14.0.0, 15.0.0)" />
    <PackageReference Include="Umbraco.Cms.Api.Management" Version="[14.0.0, 15.0.0)" />
    <PackageReference Include="Umbraco.Cms.Api.Common" Version="[14.0.0, 15.0.0)" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="[14.0.0, 15.0.0)" />
  </ItemGroup>

  <!-- Umbraco 17 packages (net10.0) -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms.Core" Version="[17.0.0, 18.0.0)" />
    <PackageReference Include="Umbraco.Cms.Infrastructure" Version="[17.0.0, 18.0.0)" />
    <PackageReference Include="Umbraco.Cms.Api.Management" Version="[17.0.0, 18.0.0)" />
    <PackageReference Include="Umbraco.Cms.Api.Common" Version="[17.0.0, 18.0.0)" />
    <PackageReference Include="Umbraco.Cms.Web.Common" Version="[17.0.0, 18.0.0)" />
  </ItemGroup>

  <ItemGroup>
    <!-- Don't include the client folder as part of packaging nuget build -->
    <Content Remove="Client\**" />

    <!-- However make the Umbraco-package.json included for dotnet pack or nuget package and visible to the solution -->
    <None Include="Client\public\umbraco-package.json" Pack="false" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="Client\scripts\" />
    <Folder Include="wwwroot\App_Plugins\" />
  </ItemGroup>

</Project>
