{
  "$schema": "../../umbraco-package-schema.json",
  "id": "FormBuilder.Extension",
  "name": "Form Builder",
  "version": "1.0.1",
  "extensions": [
    {
      "type": "section",
      "alias": "formBuilder.Section",
      "name": "FormBuilder",
      "meta": {
        "label": "Form Builder",
        "pathname": "formbuilder"
      }
    },
    {
      "type": "menuItem",
      "alias": "formBuilder.Menu.Forms",
      "name": "Forms",
      "conditions": [
        { "alias": "Umb.Condition.SectionAlias", "match": "formBuilder.Section" }
      ],
      "meta": {
        "label": "Forms",
        "icon": "icon-list",
        "menus": ["Umb.Menu.Default"],
        "entityType": ""
      }
    },
    {
      "type": "dashboard",
      "alias": "formBuilder.Dashboard.Welcome",
      "name": "Welcome",
      "element": "/App_Plugins/FormBuilderExtension/welcome-dashboard.js",
      "elementName": "formbuilder-dashboard",
      "weight": 100,
      "meta": {
        "label": "Welcome",
        "pathname": "formbuilder-dashboard"
      },
      "conditions": [
        { "alias": "Umb.Condition.SectionAlias", "match": "formBuilder.Section" }
      ]
    },
    {
      "type": "dashboard",
      "alias": "formBuilder.Dashboard.FormList",
      "name": "Form List",
      "element": "/App_Plugins/FormBuilderExtension/form-list-dashboard.js",
      "elementName": "formbuilder-form-list",
      "weight": 90,
      "meta": {
        "label": "Forms",
        "pathname": "formbuilder-list"
      },
      "conditions": [
        { "alias": "Umb.Condition.SectionAlias", "match": "formBuilder.Section" }
      ]
    },
    {
      "type": "dashboard",
      "alias": "formBuilder.Dashboard.FormEditor",
      "name": "Form Editor",
      "element": "/App_Plugins/FormBuilderExtension/form-editor-dashboard.js",
      "elementName": "formbuilder-form-editor",
      "weight": 80,
      "meta": {
        "label": "Editor",
        "pathname": "formbuilder-editor"
      },
      "conditions": [
        { "alias": "Umb.Condition.SectionAlias", "match": "formBuilder.Section" }
      ]
    }
  ]
}
