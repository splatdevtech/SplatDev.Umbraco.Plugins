{
  "$schema": "../../umbraco-package-schema.json",
  "id": "FormBuilder.Extension",
  "name": "Form Builder",
  "version": "1.0.1",
  "extensions": [
    {
      "type": "section",
      "alias": "formBuilder.Section",
      "name": "FormBuilder",
      "meta": {
        "label": "Form Builder",
        "pathname": "formbuilder"
      }
    },
    {
      "type": "dashboard",
      "alias": "formbuildeer.dashboard",
      "name": "Form Builder Dashboard",
      "element": "/App_Plugins/FormBuilderExtension/welcome-dashboard.js",
      "elementName": "formbuilder-dashboard",
      "weight": 30,
      "meta": {
        "label": "Form Builder Dashboard",
        "pathname": "formbuilder-dashboard"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "formBuilder.Section"
        }
      ]
    }
  ]
}
