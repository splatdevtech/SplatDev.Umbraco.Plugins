{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Analytics",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "UmbracoCms.Analytics.Dashboard",
      "name": "Analytics Dashboard",
      "element": "/App_Plugins/Analytics/dist/analytics-dashboard.element.js",
      "elementName": "analytics-dashboard",
      "weight": 100,
      "meta": {
        "label": "Analytics",
        "pathname": "analytics"
      },
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ]
    },
    {
      "type": "localization",
      "alias": "UmbracoCms.Analytics.Localization.En",
      "name": "Analytics — English",
      "meta": {
        "culture": "en",
        "localizations": {
          "section": {
            "analytics_heading": "Analytics",
            "analytics_description": "Configure Google Analytics GA4 integration",
            "analytics_measurementId": "Measurement ID",
            "analytics_enabled": "Enabled",
            "analytics_pageViews": "Page Views"
          }
        }
      }
    }
  ]
}
