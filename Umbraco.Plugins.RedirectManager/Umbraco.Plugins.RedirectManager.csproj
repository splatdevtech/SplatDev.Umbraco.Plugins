<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ContentTargetFolders>.</ContentTargetFolders>
  </PropertyGroup>

  <PropertyGroup>
    <PackageId>Umbraco.Plugins.RedirectManager</PackageId>
    <Product>Umbraco.Plugins.RedirectManager</Product>
    <Title>Umbraco.Plugins.RedirectManager</Title>
    <Description>Umbraco redirect manager plugin supporting Umbraco 13 (net8.0) and Umbraco 17 (net10.0)</Description>
    <PackageTags>umbraco umbraco-marketplace</PackageTags>
    <Version>2.0.0</Version>
    <Authors>SplatDev</Authors>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Umbraco.Cms.Web.Website" Version="13.12.0" />
    <PackageReference Include="Umbraco.Cms.Web.BackOffice" Version="13.12.0" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Umbraco.Cms.Web.Website" Version="17.3.4" />
    <PackageReference Include="Umbraco.Cms.Api.Management" Version="17.3.4" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="App_Plugins\Umbraco.Plugins.RedirectManager\**" ExcludeFromSingleFile="true" CopyToPublishDirectory="Always" />
    <None Include="buildTransitive\**" Pack="true" PackagePath="buildTransitive" />
  </ItemGroup>
</Project>
