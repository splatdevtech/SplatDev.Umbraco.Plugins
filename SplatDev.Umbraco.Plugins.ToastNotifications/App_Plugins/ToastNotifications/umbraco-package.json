{
  "$schema": "../../umbraco-package-schema.json",
  "name": "Toast Notifications",
  "version": "2.0.0",
  "extensions": [
    {
      "type": "dashboard",
      "alias": "SplatDev.ToastNotifications.Dashboard",
      "name": "Toast Notifications Dashboard",
      "element": "/App_Plugins/ToastNotifications/dist/dashboard.js",
      "weight": -90,
      "conditions": [
        {
          "alias": "Umb.Condition.SectionAlias",
          "match": "Umb.Section.Settings"
        }
      ],
      "elementName": "toast-notifications-dashboard",
      "meta": {
        "label": "Notifications",
        "pathname": "toast-notifications"
      }
    }
  ],
  "alias": "SplatDev.ToastNotifications"
}
