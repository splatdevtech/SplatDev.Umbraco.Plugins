<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net10.0</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<PackageId>SplatDev.Umbraco.Plugins.Countries</PackageId>
		<Version>2.0.1</Version>
    <PackageReadmeFile>README.md</PackageReadmeFile>
		<Authors>SplatDev</Authors>
		<Description>Umbraco countries data plugin supporting Umbraco 13 (net8.0) and Umbraco 17 (net10.0)</Description>
		<PackageTags>umbraco umbraco-marketplace countries data</PackageTags>
	</PropertyGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
		<PackageReference Include="Umbraco.Cms.Core" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Infrastructure" Version="13.12.0" />
		<PackageReference Include="Umbraco.Cms.Web.Common" Version="13.12.0" />
	</ItemGroup>

	<ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
		<PackageReference Include="Umbraco.Cms.Core" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Infrastructure" Version="17.3.4" />
		<PackageReference Include="Umbraco.Cms.Web.Common" Version="17.3.4" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="CsvHelper" Version="33.1.0" />
	</ItemGroup>


  <Target Name="CopyCountriesAppDataToOutput" BeforeTargets="BeforeBuild">
    <ItemGroup>
      <_CountriesAppDataFiles Include="$(MSBuildThisFileDirectory)App_Data\**\*.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_CountriesAppDataFiles)"
          DestinationFiles="@(_CountriesAppDataFiles->'$(OutDir)App_Data\SplatDev.Umbraco.Plugins.Countries\%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true" />
  </Target>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="umbraco-marketplace.json" Pack="true" PackagePath="\" Condition="Exists('umbraco-marketplace.json')" />
    <Content Include="App_Data\countries.csv" CopyToOutputDirectory="PreserveNewest" CopyToPublishDirectory="PreserveNewest" Pack="true" PackagePath="contentFiles\any\any\App_Data\SplatDev.Umbraco.Plugins.Countries\" />
    <None Include="App_Data\countries.csv" Pack="true" PackagePath="App_Data\" />
    <None Include="buildTransitive\**" Pack="true" PackagePath="buildTransitive" />
  </ItemGroup>
</Project>
